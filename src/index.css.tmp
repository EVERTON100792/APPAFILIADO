@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@400;700&display=swap');

:root {
  --bg-deep: #080B14;
  --bg-card: rgba(16, 22, 36, 0.7);
  --accent-blue: #00D1FF;
  --accent-purple: #BC00FF;
  --accent-magenta: #FF00E5;
  --text-main: #F8FAFC;
  --text-dim: #94A3B8;
  --border-glass: rgba(255, 255, 255, 0.08);
  --safe-top: env(safe-area-inset-top, 25px);
  --safe-bottom: env(safe-area-inset-bottom, 20px);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

html, body {
  height: 100%;
  width: 100%;
  overflow: hidden;
  background-color: var(--bg-deep);
  color: var(--text-main);
  font-family: 'Plus Jakarta Sans', sans-serif;
}

#root {
  height: 100%;
}

.app-container {
  min-height: 100dvh;
  width: 100%;
  max-width: 500px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  position: relative;
  background: radial-gradient(circle at top right, rgba(0, 209, 255, 0.05), transparent 40%),
              radial-gradient(circle at bottom left, rgba(188, 0, 255, 0.05), transparent 40%);
  padding-bottom: calc(85px + var(--safe-bottom));
}

header {
  min-height: 90px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--safe-top) 20px 10px;
  border-bottom: 1px solid var(--border-glass);
  flex-shrink: 0;
  background: rgba(8, 11, 20, 0.9);
  backdrop-filter: blur(25px);
  z-index: 50;
}

header h1 {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  margin-top: 5px;
}

header .accent-text {
  color: var(--accent-blue);
  text-shadow: 0 0 10px rgba(0, 209, 255, 0.4);
}

.content-area {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  scrollbar-width: thin;
  scrollbar-color: var(--accent-blue) transparent;
}

.content-area::-webkit-scrollbar {
  width: 3px;
}

.content-area::-webkit-scrollbar-thumb {
  background: var(--accent-blue);
  border-radius: 10px;
}
